								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "This inner class is just a "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "bold"
										}
									],
									"text": "namespace"
								},
								{
									"type": "text",
									"text": " — a place to group related "
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "settings/configurations together."
