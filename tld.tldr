							},
							"content": [
								{
									"type": "text",
									"text": "What is a \"class inside a class\" in Python?"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							}
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "In Python, you can define a class "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "bold"
										}
									],
									"text": "inside"
								},
								{
									"type": "text",
									"text": " another class. "
								}
