			"type": "text",
			"props": {
				"color": "black",
				"size": "xl",
				"w": 1344.828125,
				"font": "serif",
				"textAlign": "start",
				"autoSize": true,
				"scale": 1.1982704874672165,
				"richText": {
					"type": "doc",
					"attrs": {
						"dir": "auto"
					},
					"content": [
						{
							"type": "heading",
							"attrs": {
								"dir": "auto",
								"level": 2
							},
							"content": [
								{
									"type": "text",
									"text": "What is a \"class inside a class\" in Python?"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							}
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "In Python, you can define a class "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "bold"
										}
									],
									"text": "inside"
								},
								{
									"type": "text",
									"text": " another class. "
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "This inner class is just a "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "bold"
										}
									],
									"text": "namespace"
								},
								{
									"type": "text",
									"text": " — a place to group related "
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "settings/configurations together."
								}
							]
						}
					]
				}
			},
